{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth",     "dest": "/api/auth.js" },
    { "src": "/api/add-user", "dest": "/api/add-user.js" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}
